{
  "name": "@queenbee/core",
  "version": "0.1.0",
  "description": "Core logic for spawning and controlling Claude Code instances",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "dev": "tsc --watch",
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "devDependencies": {
    "@types/node": "^20.19.39",
    "@vitest/coverage-v8": "^2.1.9",
    "typescript": "^5.4.5",
    "vitest": "^2.1.9"
  },
  "dependencies": {
    "node-pty": "^1.1.0"
  }
}
