{
  "name": "queenbee",
  "private": true,
  "version": "0.1.0",
  "description": "Container for managing multiple Claude Code instances",
  "scripts": {
    "dev": "pnpm --parallel -r dev",
    "build": "pnpm -r build",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "clean": "pnpm -r clean",
    "cli:install": "pnpm build && pnpm --filter @queenbee/cli exec pnpm link --global",
    "cli:dev": "pnpm --parallel --filter @queenbee/core --filter @queenbee/cli dev"
  },
  "devDependencies": {
    "typescript": "^5.4.5"
  },
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  }
}
